# Never commit a real key. Set these values in Netlify Project configuration → Environment variables.
OPENAI_API_KEY=
KOBITS_MODEL=gpt-4.1-mini

# Private testing only. Keep false or unset for a public site until authentication is built.
KOBITS_ALLOW_UNAUTHENTICATED_DEMO=false

# Comma-separated website origins allowed to use the embedded widget, e.g. https://example.com
KOBITS_ALLOWED_ORIGINS=
